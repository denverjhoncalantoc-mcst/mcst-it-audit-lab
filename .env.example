# Optional: only set if hosting under a subpath (e.g. https://alumnilink.com/peis002/)
# Must start and end with a slash when set.
# VITE_BASE_PATH=/peis002/

# Admin login (required for /admin laboratory control panel)
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_SESSION_SECRET=your-random-session-secret

# Persist enabled laboratories via GitHub (recommended on Vercel)
GITHUB_TOKEN=
GITHUB_REPO=denverjhoncalantoc-mcst/mcst-it-audit-lab
GITHUB_BRANCH=main

# Fallback when labs-config.json is unavailable
ENABLED_LAB_IDS=1
